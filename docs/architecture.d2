direction: down
explanation: |md
  ### rewardfuzz
  **Attack your reward function before it attacks your training run** — a preventive, a-priori auditor for reward / fitness / verifier functions.
| {near: top-center}

target: "① Target reward fn" {shape: oval; style: {fill: "#6366f1"; font-color: "#fff"; stroke: "#4338ca"; bold: true; font-size: 18}}

adapter: "② Adapter\ncallable / openevolve / rlvr" {style: {fill: "#0ea5e9"; font-color: "#fff"; stroke: "#0369a1"; bold: true; font-size: 18}}

strategies: "Attack Strategies" {
  style: {fill: "#f0fdf4"; stroke: "#10b981"; font-color: "#065f46"; bold: true; font-size: 16}
  s1: "③ degenerate"
  s2: "③ numeric_exploit"
  s3: "③ test_tamper"
  s4: "③ side_effect"
  s5: "③ llm_specgaming\n(optional)"
  *.style.fill: "#dcfce7"; *.style.font-color: "#065f46"
}

sandbox: "④ Sandboxed eval\nAST pre-scan + subprocess\nscrubbed env + setrlimit" {style: {fill: "#0ea5e9"; font-color: "#fff"; stroke: "#0369a1"; bold: true}}

judge: "⑤ Judge\nstructural invariants\noptional LLM ensemble" {style: {fill: "#fffbeb"; font-color: "#92400e"; stroke: "#f59e0b"; bold: true}}

scoring: "⑥ Scoring\nnoisy-OR composite\nbootstrap CI" {style: {fill: "#0ea5e9"; font-color: "#fff"; stroke: "#0369a1"; bold: true}}

report: "⑦ AuditReport\nHackability score\nFindings + Hardening tips" {shape: cylinder; style: {fill: "#fdf2f8"; font-color: "#9d174e"; stroke: "#ec4899"; bold: true}}

target -> adapter: "① wrap"
adapter -> strategies.s1: "② fuzz"
